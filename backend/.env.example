# =====================================================================
# openGecko 开发环境配置模板
# 此文件由 backend/scripts/generate_env_example.py 自动生成
# 复制为 backend/.env：  cp backend/.env.example backend/.env
# 生产环境请参考 backend/.env.prod.example
# =====================================================================

# ─────────────────────────────────────────────────────────────────────
# 数据库
# ─────────────────────────────────────────────────────────────────────
# 数据库连接 URL。开发: sqlite:///./data/opengecko.db
# 生产推荐 PostgreSQL: postgresql://user:pass@host:5432/db
DATABASE_URL=sqlite:///./data/opengecko.db
# 数据库连接池大小（PostgreSQL/MySQL 生效）
# DB_POOL_SIZE=5
# 连接池最大溢出连接数
# DB_MAX_OVERFLOW=10
# 获取连接的超时秒数
# DB_POOL_TIMEOUT=30
# 连接回收时间（秒），防止数据库长连接断开
# DB_POOL_RECYCLE=3600
# 是否打印所有 SQL 语句（调试用，生产禁用）
# DB_ECHO=false

# ─────────────────────────────────────────────────────────────────────
# 安全 / JWT
# ─────────────────────────────────────────────────────────────────────
# JWT 签名密钥（⚠️ 生产环境必须替换，建议 `openssl rand -hex 32` 生成）
JWT_SECRET_KEY=change-me-in-production-please-use-a-strong-secret-key
# JWT 签名算法
# JWT_ALGORITHM=HS256
# 访问令牌有效期（分钟）。默认 7 天 = 10080 分钟
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────────────────────────────
# CORS 跨域
# ─────────────────────────────────────────────────────────────────────
# 允许的跨域来源，多个地址用英文逗号分隔。生产环境示例:
# https://app.example.com,https://admin.example.com
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────
# 速率限制
# ─────────────────────────────────────────────────────────────────────
# 登录端点速率限制（防止暴力破解）。格式: <次数>/<单位>，单位可为 second/minute/hour
# RATE_LIMIT_LOGIN=10/minute
# 默认 API 端点速率限制
# RATE_LIMIT_DEFAULT=120/minute

# ─────────────────────────────────────────────────────────────────────
# 初始管理员（仅首次启动时创建）
# ─────────────────────────────────────────────────────────────────────
# 初始管理员用户名（首次启动时创建）
DEFAULT_ADMIN_USERNAME=admin
# 初始管理员密码（⚠️ 生产环境首次启动后立即修改）
DEFAULT_ADMIN_PASSWORD=admin123
# 初始管理员邮箱
DEFAULT_ADMIN_EMAIL=admin@example.com

# ─────────────────────────────────────────────────────────────────────
# SMTP 邮件（可选，用于密码重置和通知）
# ─────────────────────────────────────────────────────────────────────
# SMTP 服务器地址（留空则禁用邮件功能）
# SMTP_HOST=
# SMTP 端口（587=STARTTLS，465=SSL）
# SMTP_PORT=587
# SMTP 登录用户名
# SMTP_USER=
# SMTP 登录密码
# SMTP_PASSWORD=
# 发件人邮箱地址
# SMTP_FROM_EMAIL=
# 是否使用 TLS/STARTTLS 加密连接
# SMTP_USE_TLS=true

# ─────────────────────────────────────────────────────────────────────
# 前端地址（密码重置邮件跳转链接）
# ─────────────────────────────────────────────────────────────────────
# 前端访问地址，用于生成密码重置链接邮件中的跳转 URL
# FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# 文件存储
# ─────────────────────────────────────────────────────────────────────
# 单次上传文件大小上限（字节）。默认 50MB = 52428800
# MAX_UPLOAD_SIZE=52428800
# 文件存储后端。local：本地文件系统（开发默认）
# s3：S3 兼容对象存储（MinIO / AWS S3 / 华为 OBS 等，生产推荐）
# STORAGE_BACKEND=local

# ─────────────────────────────────────────────────────────────────────
# S3 / MinIO 对象存储（STORAGE_BACKEND=s3 时填写）
# ─────────────────────────────────────────────────────────────────────
# S3 兼容存储的访问端点。MinIO Docker 内网: http://minio:9000
# AWS S3: https://s3.amazonaws.com
# 华为 OBS: https://obs.<region>.myhuaweicloud.com
# S3_ENDPOINT_URL=http://minio:9000
# S3/MinIO Access Key（用户名）
# S3_ACCESS_KEY=minioadmin
# S3/MinIO Secret Key（密码）
# S3_SECRET_KEY=minioadmin
# S3 Bucket 名称
# S3_BUCKET=opengecko
# Bucket 的公开访问基础 URL（nginx 将 /uploads/ 代理到此地址）。内网部署保持默认
# 对外暴露时改为公网域名
# S3_PUBLIC_URL=http://minio:9000/opengecko

# ─────────────────────────────────────────────────────────────────────
# 时区
# ─────────────────────────────────────────────────────────────────────
# 服务端时区，影响 ICS 日历和邮件通知中的时间显示。数据库始终以 UTC 存储，此配置仅控制输出本地化。IANA 时区列表:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
APP_TIMEZONE=Asia/Shanghai

# ─────────────────────────────────────────────────────────────────────
# 生态洞察采集服务
# ─────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token。格式: ghp_xxxx
# 不填则受 60 req/h 匿名限速
# GITHUB_TOKEN=
# 项目默认采集间隔（小时）。项目级 sync_interval_hours 字段优先
# COLLECTOR_SYNC_INTERVAL_HOURS=24
# 并发采集线程数
# COLLECTOR_MAX_WORKERS=4
# 独立采集器主循环检查间隔（秒）。默认 1 小时检查一次哪些项目到期
# COLLECTOR_CHECK_INTERVAL_SECONDS=3600
# True = 采集器嵌入 FastAPI 进程（APScheduler），适合单节点部署
# False = 关闭嵌入调度，由外部 `python run_collector.py` 独立进程接管，适合生产容器化
# COLLECTOR_EMBEDDED=true

# ─────────────────────────────────────────────────────────────────────
# 可选功能模块
# ─────────────────────────────────────────────────────────────────────
# 启用「洞察与人脉」模块（人脉管理 + 生态洞察）。设为 false 则不加载相关 API 路由，前端自动隐藏对应菜单。
# ENABLE_INSIGHTS_MODULE=true

# ─────────────────────────────────────────────────────────────────────
# 服务器
# ─────────────────────────────────────────────────────────────────────
# 调试模式（生产环境必须设为 false）
DEBUG=false
# 服务监听地址
# HOST=0.0.0.0
# 服务监听端口
# PORT=8000
# 日志级别。可选: debug / info / warning / error / critical
# LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────
# 应用
# ─────────────────────────────────────────────────────────────────────
# 应用名称
# APP_NAME=openGecko

